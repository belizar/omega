{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Omega",
  "version": "0.1.0",
  "identifier": "app.omega.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Ω Omega",
        "url": "http://localhost:4477",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
